{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MG Enterprise",
  "version": "0.1.0",
  "identifier": "com.clarix.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MG Enterprise",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' asset: http://asset.localhost data: blob: http: https:; media-src 'self' asset: http://asset.localhost blob: http: https:; connect-src 'self' ipc: http://ipc.localhost http: https:; frame-src 'self' http: https:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/media/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../out/": "browser-player/"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
